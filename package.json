{
  "name": "@shamilkotta/ghcp",
  "version": "0.1.0",
  "description": "Download a file or folder from a public GitHub link.",
  "keywords": [
    "cli",
    "copy",
    "download",
    "fetch",
    "github",
    "github-cli",
    "repository"
  ],
  "homepage": "https://github.com/shamilkotta/ghcp#readme",
  "bugs": {
    "url": "https://github.com/shamilkotta/ghcp/issues"
  },
  "license": "MIT",
  "author": "shamilkotta",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shamilkotta/ghcp.git"
  },
  "bin": {
    "ghcp": "./dist/cli.mjs"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "pnpm build && node dist/cli.mjs",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "check": "pnpm format:check && pnpm lint && pnpm build",
    "prepack": "pnpm run build",
    "prepublishOnly": "pnpm run check"
  },
  "dependencies": {
    "effect": "^3.21.2"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "tsdown": "^0.22.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.1.1"
}
